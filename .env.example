# Day 22 lab — env template. Copy to .env and fill in.
# Default tier is T4 (free Colab). Use LIGHT for low-RAM machines, BIGGPU for 7B.

# ───────────────────────────────────────────────────────────
# Compute tier — picks model size, batch, dataset slice
# ───────────────────────────────────────────────────────────
COMPUTE_TIER=T4                     # LIGHT | T4 | BIGGPU
LOW_MEM=0                           # set 1 to force the LIGHT path

# LIGHT → Qwen2.5-0.5B-Instruct, 500 pref pairs, max_length=384, no Unsloth kernels
# T4   → Qwen2.5-3B-bnb-4bit, 1k pref pairs, max_length=512, batch=1 grad_accum=8
# BIGGPU → Qwen2.5-7B-bnb-4bit, 5k pref pairs, max_length=1024, batch=2 grad_accum=4

# ───────────────────────────────────────────────────────────
# Model + dataset overrides (optional — defaults set by COMPUTE_TIER)
# ───────────────────────────────────────────────────────────
# BASE_MODEL=unsloth/Qwen2.5-3B-bnb-4bit
# SFT_DATASET=5CD-AI/Vietnamese-alpaca-cleaned
# PREF_DATASET=argilla/ultrafeedback-binarized-preferences-cleaned
# SFT_SLICE=300
# PREF_SLICE=1000
# MAX_LEN=384
# MAX_PROMPT_LEN=192
# GRAD_ACCUM=4

# ───────────────────────────────────────────────────────────
# DPO hyperparameters (defaults match deck §5.2)
# ───────────────────────────────────────────────────────────
DPO_BETA=0.1
DPO_LR=5e-7
DPO_EPOCHS=1

# ───────────────────────────────────────────────────────────
# Optional: API judges for notebook 04 (only if you have keys)
# Without keys, notebook 04 falls back to manual rubric mode.
# ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# JUDGE_MODEL=gpt-4o-mini             # gpt-4o-mini | claude-haiku-4-5

# ───────────────────────────────────────────────────────────
# Optional: HuggingFace push (Submission Option B = +5 bonus)
# ───────────────────────────────────────────────────────────
# HF_TOKEN=hf_...
# HF_REPO=<your-username>/lab22-dpo-vn

# ───────────────────────────────────────────────────────────
# Optional: Weights & Biases (one of the +20 bonus rigor add-ons)
# ───────────────────────────────────────────────────────────
# WANDB_API_KEY=...
# WANDB_PROJECT=lab22-dpo
